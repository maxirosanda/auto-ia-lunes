      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Caso 1: múltiples items (lo más común en n8n)\nif (items.length > 1) {\n  return items.map((item, index) => {\n    const d = item.json;\n\n    return {\n      json: {\n        text: `ID: ${d.ID}, Nombre: ${d.Nombre}, Edad: ${d.Edad}, Pais: ${d.Pais}, IngresoMensual: ${d.IngresoMensual}`,\n        source: \"ejemplo_datos\",\n        chunk_index: index,\n        chunk_id: `ejemplo_datos_${index}`\n      }\n    };\n  });\n}\n\n// Caso 2: un solo item con array adentro\nlet data = items[0].json;\n\n// si viene como { data: [...] }\nif (Array.isArray(data.data)) {\n  data = data.data;\n}\n\n// si viene como array directo\nelse if (Array.isArray(data)) {\n  // ok\n}\n\n// si viene como objeto único\nelse {\n  data = [data];\n}\n\nreturn data.map((item, index) => {\n  return {\n    json: {\n      text: `ID: ${item.ID}, Nombre: ${item.Nombre}, Edad: ${item.Edad}, Pais: ${item.Pais}, IngresoMensual: ${item.IngresoMensual}`,\n      source: \"ejemplo_datos\",\n      chunk_index: index,\n      chunk_id: `ejemplo_datos_${index}`\n    }\n  };\n});"
      },

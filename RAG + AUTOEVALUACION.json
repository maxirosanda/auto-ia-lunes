    {
      "parameters": {
        "content": "# 1. Api REST (v)\n# 2. Webhooks (v)\n# 3. Fallbacks\n# 4. Observabilidad\n# 5. RAG (v)\n# 6. multimodalidad\n# 7. Human-in-the-Loop\n# 8. Autoevaluación (v)",
        "height": 480,
        "width": 464
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        352,
        -1440
      ],
      "typeVersion": 1,
      "id": "57f81e70-79a2-49d0-b866-c00aeca491d8",
      "name": "Sticky Note16",
      "disabled": true
    },
    {
      "parameters": {
        "jsCode": "// --- INPUT ---\nconst items = $input.all();\n\n// embedding respuesta\nconst responseEmbedding = items[0].json.embedding.values;\n\n// embeddings fragmentos\nconst fragmentEmbeddings = items\n    .slice(1)\n    .map(item => item.json.embedding.values);\n\n// --- COSINE SIMILARITY ---\nfunction cosineSimilarity(a, b) {\n    if (!a || !b || a.length !== b.length) return 0;\n\n    let dot = 0, normA = 0, normB = 0;\n\n    for (let i = 0; i < a.length; i++) {\n        dot += a[i] * b[i];\n        normA += a[i] * a[i];\n        normB += b[i] * b[i];\n    }\n\n    if (normA === 0 || normB === 0) return 0;\n\n    return dot / (Math.sqrt(normA) * Math.sqrt(normB));\n}\n\n// --- 1. SIMILITUDES ---\nconst similarities = fragmentEmbeddings.map(f =>\n    cosineSimilarity(responseEmbedding, f)\n);\n\n// --- 2. TOP-K ---\nconst K = 3;\nconst sorted = [...similarities].sort((a, b) => b - a);\nconst topK = sorted.slice(0, K);\n\n// --- 3. PROMEDIO TOP-K ---\nconst avgTopK = topK.reduce((a, b) => a + b, 0) / topK.length;\n\n// --- 4. BONUS POR CONSISTENCIA (opcional) ---\n// si más de 2 fragmentos son bastante similares → suma confianza\nconst strongMatches = similarities.filter(s => s > 0.75).length;\nconst consistencyBonus = Math.min(strongMatches * 0.02, 0.05);\n\n// --- 5. SCORE FINAL ---\nconst finalScore = Math.min(avgTopK + consistencyBonus, 1);\n\n// --- OUTPUT ---\nreturn [\n  {\n    json: {\n      finalScore,\n      avgTopK,\n      consistencyBonus,\n      similarities,\n      topK,\n      fragmentCount: similarities.length\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2016,
        -592
      ],
      "id": "729f6419-daec-4ffe-b581-565269e2755b",
      "name": "Generador Score"
    },
    {
      "parameters": {
        "jsCode": "// Obtener almacenamiento global del workflow\nconst globalData = $getWorkflowStaticData('global');\n\n// Inicializar si no existe\nif (globalData.counter === undefined) {\n  globalData.counter = 0;\n}\n\n// Incrementar contador\nglobalData.counter += 1;\n\n// Devolver resultado\nreturn items.map(item => ({\n  json: {\n    ...item.json,\n    counter: globalData.counter\n  }\n}));"
      },
